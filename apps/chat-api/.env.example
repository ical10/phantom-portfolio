# ---------------------------------------------------------------------------
# chat-api — environment variables
# ---------------------------------------------------------------------------
# Copy to `.env` for local dev, or set as service variables on your hosting
# platform. Everything here is SERVER-SIDE; never expose to the browser.
# ---------------------------------------------------------------------------

# Port the Hono server listens on. Many platforms inject their own $PORT at
# runtime — leave unset there. Locally defaults to 8787 if omitted.
PORT=8787

# Comma-separated list of origins allowed to hit this API. Must include the
# TanStack Start dev URL locally and the deployed web URL in prod.
#   - local dev:  http://localhost:3000
#   - prod:       https://your-web-host.example.com,https://yourdomain.tld
ALLOWED_ORIGINS=http://localhost:3000

# Anthropic API key for the Claude Agent SDK that powers POST /chat.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# @phantom/mcp-server writes device-auth state to this directory. On any
# host with ephemeral filesystems, persist it via a mounted volume if you
# don't want to re-auth on every deploy.
# PHANTOM_MCP_HOME=/data/phantom-mcp

# Optional: pin the MCP server binary if you're not using npx.
# PHANTOM_MCP_BIN=npx @phantom/mcp-server
