# ---------------------------------------------------------------------------
# web — environment variables
# ---------------------------------------------------------------------------
# TanStack Start reads these at build time and at runtime inside server fns.
# Vars prefixed with `VITE_` are inlined into the browser bundle; everything
# else is server-only and must never appear in a client component.
# ---------------------------------------------------------------------------

# --- Server-only (read via process.env inside src/lib/*.ts server modules) ---

# Solana RPC — Helius free tier: https://dashboard.helius.dev/
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=XXXXXXXXXXXX

# EVM RPCs — Alchemy free tier: https://dashboard.alchemy.com/
ALCHEMY_ETH_RPC=https://eth-mainnet.g.alchemy.com/v2/XXXXXXXXXXXX
ALCHEMY_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/XXXXXXXXXXXX

# Price data providers
COINGECKO_BASE=https://api.coingecko.com/api/v3
JUPITER_PRICE_BASE=https://lite-api.jup.ag/price/v3
# Leave blank for the demo tier; set when you upgrade.
JUPITER_API_KEY=

# --- Client-exposed (inlined into the browser bundle at build time) ---

# Phantom Embedded Wallet SDK app id — phantom.com/portal
VITE_PHANTOM_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Absolute URL the browser is served from. Used by the Phantom SDK for
# redirect/origin validation.
#   - local:  http://localhost:3000
#   - prod:   https://<your-web-url>.pages.dev  (or your custom domain)
VITE_APP_URL=http://localhost:3000

# Base URL for the chat-api Hono service
#   - local:  http://localhost:8787
#   - prod:   https://<your-railway-service>.up.railway.app
VITE_CHAT_API_URL=http://localhost:8787
